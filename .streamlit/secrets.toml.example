# Copy this file to .streamlit/secrets.toml and fill in real values.
# Generate password hashes with: python scripts/hash_password.py
# This file must NOT be committed to git.

# ── Main app authentication ───────────────────────────────────────────────────

[auth]
cookie_name = "maint_plan_auth"
cookie_key  = "REPLACE_WITH_RANDOM_32_CHAR_STRING"
cookie_expiry_days = 30

[auth.credentials.usernames.jvisser]
name     = "Johann Visser"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role     = "planner"

[auth.credentials.usernames.demo]
name     = "Demo User"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role     = "viewer"

# ── Admin app authentication (also used by admin/app_admin.py) ────────────────

[auth_admin]
cookie_name = "maint_admin_auth"
cookie_key  = "REPLACE_WITH_DIFFERENT_RANDOM_32_CHAR_STRING"
cookie_expiry_days = 30

[auth_admin.credentials.usernames.jason]
name     = "Jason (SME)"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role     = "admin"

# ── Anthropic API ─────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY = "sk-ant-..."
